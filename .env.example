# Copy to .env and fill in values

# --- API (optional) ---
# Base API URL (without endpoint suffix)
CONTENTFORGE_URL=https://contentforge.1344.fr/api/v1
# API token for fetching dynamic content (e.g., FAQs)
CONTENTFORGE_API_TOKEN=

# --- i18n toggle ---
# Set to "true" to enable French/English language switcher
# Set to "false" for single-language (French) site
ENABLE_MULTILANG=false
