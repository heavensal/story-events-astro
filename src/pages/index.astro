---
import HeroMinimal from '../components/HeroMinimal.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { pageHref } from '../lib/paths';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<HeroMinimal primaryHref="#contact" secondaryHref="#contenu" secondaryLabel="Découvrir" />
		<section id="contenu" class="py-16 md:py-20 px-4 bg-gray-50">
			<div class="container mx-auto max-w-3xl prose prose-gray prose-lg">
				<h2 class="text-2xl font-bold text-gray-900 not-prose mb-4">Bloc éditorial — à modifier</h2>
				<p>
					Remplacez ce paragraphe par votre pitch : offre, zone géographique, différenciation. Ce template est volontairement
					minimal (Astro + Tailwind) pour une mise en ligne rapide sur GitHub Pages.
				</p>
				<p>
					Adaptez <code class="text-sm bg-gray-200 px-1 rounded">src/site.config.ts</code> (nom, description SEO, contact) et
					<code class="text-sm bg-gray-200 px-1 rounded">astro.config.mjs</code> (<code class="text-sm">site</code> et{' '}
					<code class="text-sm">base</code> pour GitHub Pages).
				</p>
			</div>
		</section>
		<section id="contact" class="py-16 px-4">
			<div class="container mx-auto max-w-xl text-center">
				<h2 class="text-2xl font-bold text-gray-900 mb-6">Contact</h2>
				<p class="text-gray-600 mb-6">Section contact — à remplacer par un formulaire, une carte ou vos liens réseaux.</p>
				<a
					href={pageHref('mentions-legales')}
					class="text-emerald-600 hover:text-emerald-700 font-medium text-sm"
				>
					Mentions légales et politiques →
				</a>
			</div>
		</section>
		<SiteFooter />
	</main>
</Layout>
