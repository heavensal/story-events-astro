---
import HeroMinimal from '../components/HeroMinimal.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { pageHref } from '../lib/paths';
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../site.config';

const { email } = siteConfig.contact;
---

<Layout>
	<main>
		<HeroMinimal primaryHref="#contact" secondaryHref="#offre" secondaryLabel="L’offre B2B" />

		<section id="offre" class="relative py-20 md:py-28 px-4 bg-surface-900 border-y border-white/[0.06]">
			<div class="container mx-auto max-w-5xl">
				<header class="text-center max-w-2xl mx-auto mb-16 md:mb-20">
					<h2 class="font-display text-3xl md:text-4xl font-semibold text-silver-100 mb-4">
						Votre sous-traitant service, au niveau de votre marque
					</h2>
					<p class="text-silver-400 leading-relaxed">
						Lorsque vous signez un mariage, une cérémonie ou une conférence, le service en salle porte votre réputation.
						Story Events constitue des équipes formées — maîtres d’hôtel, serveurs — qui prolongent votre exigence traiteur,
						avec discrétion et tenue irréprochable.
					</p>
				</header>
				<div class="grid md:grid-cols-3 gap-6 md:gap-8">
					<div class="rounded-sm border border-white/[0.08] bg-surface-850/80 p-8 backdrop-blur-sm">
						<p class="font-display text-silver-300 text-xl mb-3">B2B uniquement</p>
						<p class="text-silver-500 text-sm leading-relaxed">
							Nous travaillons avec les entreprises du traiteur et de l’événementiel : vous gardez la relation client, nous
							déployons le personnel sur vos briefs.
						</p>
					</div>
					<div class="rounded-sm border border-white/[0.08] bg-surface-850/80 p-8 backdrop-blur-sm md:border-silver-400/25 md:shadow-[0_0_60px_-20px_rgba(200,204,212,0.15)]">
						<p class="font-display text-silver-200 text-xl mb-3">Qualité constatée</p>
						<p class="text-silver-500 text-sm leading-relaxed">
							Recrutement sélectif, tenue adaptée à votre charte, attitude alignée sur le haut de gamme. Un interlocuteur
							dédié pour caler les effectifs et le déroulé.
						</p>
					</div>
					<div class="rounded-sm border border-white/[0.08] bg-surface-850/80 p-8 backdrop-blur-sm">
						<p class="font-display text-silver-300 text-xl mb-3">Réactivité</p>
						<p class="text-silver-500 text-sm leading-relaxed">
							Mariages, cocktails d’entreprise, séminaires, galas : nous montons les équipes selon vos contraintes de
							planning et de volume.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="py-20 md:py-24 px-4 bg-surface-950">
			<div class="container mx-auto max-w-5xl">
				<div class="grid md:grid-cols-2 gap-14 md:gap-20 items-start">
					<div>
						<h2 class="font-display text-3xl md:text-4xl font-semibold text-silver-100 mb-6">Métiers &amp; rôles</h2>
						<ul class="space-y-4 text-silver-400">
							<li class="flex gap-3">
								<span class="text-silver-300 shrink-0 mt-0.5" aria-hidden="true">◆</span>
								<span><strong class="text-silver-200 font-medium">Maîtres d’hôtel</strong> — coordination du service, accueil des convives, respect du protocole.</span>
							</li>
							<li class="flex gap-3">
								<span class="text-silver-300 shrink-0 mt-0.5" aria-hidden="true">◆</span>
								<span><strong class="text-silver-200 font-medium">Serveurs / serveuses</strong> — mise en place, service à l’assiette ou à la française, bar si besoin.</span>
							</li>
							<li class="flex gap-3">
								<span class="text-silver-300 shrink-0 mt-0.5" aria-hidden="true">◆</span>
								<span><strong class="text-silver-200 font-medium">Renforts ponctuels</strong> — pics d’activité, grands formats, événements multi-sites.</span>
							</li>
						</ul>
					</div>
					<div>
						<h2 class="font-display text-3xl md:text-4xl font-semibold text-silver-100 mb-6">Types d’événements</h2>
						<ul class="space-y-4 text-silver-400">
							<li class="flex gap-3">
								<span class="text-silver-300 shrink-0 mt-0.5" aria-hidden="true">◆</span>
								<span>Mariages et cérémonies privées</span>
							</li>
							<li class="flex gap-3">
								<span class="text-silver-300 shrink-0 mt-0.5" aria-hidden="true">◆</span>
								<span>Réceptions d’entreprise, conférences, séminaires</span>
							</li>
							<li class="flex gap-3">
								<span class="text-silver-300 shrink-0 mt-0.5" aria-hidden="true">◆</span>
								<span>Cocktails, galas, lancements</span>
							</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section id="contact" class="py-20 md:py-28 px-4 bg-surface-900 border-t border-white/[0.06]">
			<div class="container mx-auto max-w-xl text-center">
				<h2 class="font-display text-3xl md:text-4xl font-semibold text-silver-100 mb-4">Échanger sur un partenariat</h2>
				<p class="text-silver-400 mb-10 leading-relaxed">
					Expliquez-nous vos formats habituels et vos exigences : nous revenons vers vous avec une proposition d’équipe et
					un cadre clair pour vos prochains événements.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-10">
					<a
						href={`mailto:${email}`}
						class="inline-flex items-center justify-center px-8 py-3.5 bg-gradient-to-b from-silver-300 to-silver-400 text-surface-950 font-semibold rounded-sm hover:from-silver-200 hover:to-silver-300 transition-all"
					>
						Écrire à Story Events
					</a>
				</div>
				<p class="text-silver-500 text-sm">
					<a href={pageHref('mentions-legales')} class="link-silver">Mentions légales et politiques</a>
				</p>
			</div>
		</section>
		<SiteFooter />
	</main>
</Layout>
