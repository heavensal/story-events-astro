---
/**
 * Layout — SEO, accessibilité, OG/Twitter, JSON-LD, polices auto-hébergées (Fontsource).
 */
import "@fontsource-variable/afacad";
import "@fontsource-variable/manrope/wght.css";
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/500.css";
import "@fontsource/cormorant-garamond/600.css";
import "@fontsource/cormorant-garamond/700.css";
import "../styles/global.css";
import { pageHref } from "../lib/paths";
import { siteConfig } from "../site.config";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	robots?: string;
	lang?: string;
	ogLocale?: string;
	/** Autre locale Open Graph (ex. en_US sur la page FR). */
	ogLocaleAlternate?: string;
	/** Liens hreflang (landing bilingue). */
	alternateLanguages?: { hreflang: string; href: string }[];
	/** Données structurées JSON-LD. */
	jsonLd?: Record<string, unknown>;
	/** Texte accessible du lien « skip to content ». */
	skipToContentLabel?: string;
	/** Texte alternatif OG/Twitter si `og:image` est défini. */
	ogImageAlt?: string;
}

const {
	title: titleProp,
	description: descriptionProp,
	image: imageProp,
	robots = "index, follow",
	lang: langProp,
	ogLocale: ogLocaleProp,
	ogLocaleAlternate,
	alternateLanguages,
	jsonLd,
	skipToContentLabel = "Aller au contenu principal",
	ogImageAlt,
} = Astro.props;

const htmlLang = langProp ?? siteConfig.lang;
const ogLocale = ogLocaleProp ?? siteConfig.locale;
const pageTitle = titleProp ?? siteConfig.name;
const description = descriptionProp ?? siteConfig.defaultDescription;

const canonical =
	Astro.site != null
		? new URL(Astro.url.pathname, Astro.site).href
		: undefined;

function absolutePublic(path: string): string | undefined {
	if (!Astro.site) return undefined;
	const p = path.startsWith("/") ? path.slice(1) : path;
	return new URL(import.meta.env.BASE_URL + p, Astro.site).href;
}

const ogImage =
	imageProp ??
	(siteConfig.ogImageUrl
		? siteConfig.ogImageUrl.startsWith("http")
			? siteConfig.ogImageUrl
			: absolutePublic(siteConfig.ogImageUrl)
		: undefined);

const jsonLdString = jsonLd
	? JSON.stringify(jsonLd).replace(/</g, "\\u003c")
	: null;
---

<!DOCTYPE html>
<html lang={htmlLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content={siteConfig.themeColor} />
		<meta name="author" content={siteConfig.name} />

		<link rel="icon" type="image/svg+xml" href={pageHref("favicon.svg")} />
		<link rel="icon" href={pageHref("favicon.ico")} sizes="any" />
		<link rel="apple-touch-icon" href={pageHref("favicon.ico")} />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />

		{canonical && <link rel="canonical" href={canonical} />}
		{
			alternateLanguages?.map(({ hreflang, href }) => (
				<link rel="alternate" hreflang={hreflang} href={href} />
			))
		}

		<meta property="og:type" content="website" />
		<meta property="og:locale" content={ogLocale} />
		{
			ogLocaleAlternate && (
				<meta
					property="og:locale:alternate"
					content={ogLocaleAlternate}
				/>
			)
		}
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		{canonical && <meta property="og:url" content={canonical} />}
		{ogImage && <meta property="og:image" content={ogImage} />}
		{
			ogImage && siteConfig.ogImageWidth > 0 && (
				<meta
					property="og:image:width"
					content={String(siteConfig.ogImageWidth)}
				/>
			)
		}
		{
			ogImage && siteConfig.ogImageHeight > 0 && (
				<meta
					property="og:image:height"
					content={String(siteConfig.ogImageHeight)}
				/>
			)
		}
		{
			ogImage && ogImageAlt && (
				<meta property="og:image:alt" content={ogImageAlt} />
			)
		}

		<meta
			name="twitter:card"
			content={ogImage ? "summary_large_image" : "summary"}
		/>
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{
			siteConfig.twitterHandle && (
				<meta
					name="twitter:site"
					content={`@${siteConfig.twitterHandle.replace(/^@/, "")}`}
				/>
			)
		}
		{ogImage && <meta name="twitter:image" content={ogImage} />}
		{
			ogImage && ogImageAlt && (
				<meta name="twitter:image:alt" content={ogImageAlt} />
			)
		}

		{
			jsonLdString && (
				<script type="application/ld+json" set:html={jsonLdString} />
			)
		}
	</head>
	<body
		class="font-sans min-h-screen antialiased bg-dark text-silver-200"
	>
		<a class="skip-link" href="#main-content">{skipToContentLabel}</a>
		<slot />
	</body>
</html>
