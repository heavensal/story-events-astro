---
/**
 * Layout — SEO (title, description, canonical, Open Graph, Twitter), favicon, langue.
 */
import '../styles/global.css';
import { pageHref } from '../lib/paths';
import { siteConfig } from '../site.config';

interface Props {
	title?: string;
	description?: string;
	/** URL absolue de l’image OG ; sinon `siteConfig.ogImageUrl` (chemin relatif à la racine du site déployé) */
	image?: string;
	robots?: string;
	/** Attribut `lang` de `<html>` (landing i18n). */
	lang?: string;
	/** `og:locale` (ex. fr_FR, en_US). */
	ogLocale?: string;
}

const {
	title: titleProp,
	description: descriptionProp,
	image: imageProp,
	robots = 'index, follow',
	lang: langProp,
	ogLocale: ogLocaleProp,
} = Astro.props;

const htmlLang = langProp ?? siteConfig.lang;
const ogLocale = ogLocaleProp ?? siteConfig.locale;
const pageTitle = titleProp ?? siteConfig.name;
const description = descriptionProp ?? siteConfig.defaultDescription;

const canonical =
	Astro.site != null
		? new URL(Astro.url.pathname, Astro.site).href
		: undefined;

function absolutePublic(path: string): string | undefined {
	if (!Astro.site) return undefined;
	const p = path.startsWith('/') ? path.slice(1) : path;
	return new URL(import.meta.env.BASE_URL + p, Astro.site).href;
}

const ogImage =
	imageProp ??
	(siteConfig.ogImageUrl
		? siteConfig.ogImageUrl.startsWith('http')
			? siteConfig.ogImageUrl
			: absolutePublic(siteConfig.ogImageUrl)
		: undefined);

const fontHref =
	'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Manrope:wght@300;400;500;600;700&display=swap';
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href={fontHref} />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content={siteConfig.themeColor} />

		<link rel="icon" type="image/svg+xml" href={pageHref('favicon.svg')} />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />

		{canonical && <link rel="canonical" href={canonical} />}

		<meta property="og:type" content="website" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		{canonical && <meta property="og:url" content={canonical} />}
		{ogImage && <meta property="og:image" content={ogImage} />}

		<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{siteConfig.twitterHandle && (
			<meta name="twitter:site" content={`@${siteConfig.twitterHandle.replace(/^@/, '')}`} />
		)}
		{ogImage && <meta name="twitter:image" content={ogImage} />}
	</head>
	<body class="min-h-screen antialiased bg-surface-950 text-silver-200">
		<slot />
	</body>
</html>
