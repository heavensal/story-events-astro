---
/**
 * Layout — SEO (title, description, canonical, Open Graph, Twitter), favicon, langue.
 */
import '../styles/global.css';
import { pageHref } from '../lib/paths';
import { siteConfig } from '../site.config';

interface Props {
	title?: string;
	description?: string;
	/** URL absolue de l’image OG ; sinon `siteConfig.ogImageUrl` (chemin relatif à la racine du site déployé) */
	image?: string;
	robots?: string;
}

const {
	title: titleProp,
	description: descriptionProp,
	image: imageProp,
	robots = 'index, follow',
} = Astro.props;

const pageTitle = titleProp ?? `${siteConfig.name} — ${siteConfig.tagline}`;
const description = descriptionProp ?? siteConfig.defaultDescription;

const canonical =
	Astro.site != null
		? new URL(Astro.url.pathname, Astro.site).href
		: undefined;

function absolutePublic(path: string): string | undefined {
	if (!Astro.site) return undefined;
	const p = path.startsWith('/') ? path.slice(1) : path;
	return new URL(import.meta.env.BASE_URL + p, Astro.site).href;
}

const ogImage =
	imageProp ??
	(siteConfig.ogImageUrl
		? siteConfig.ogImageUrl.startsWith('http')
			? siteConfig.ogImageUrl
			: absolutePublic(siteConfig.ogImageUrl)
		: undefined);

---

<!doctype html>
<html lang={siteConfig.lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content={siteConfig.themeColor} />

		<link rel="icon" type="image/svg+xml" href={pageHref('favicon.svg')} />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />

		{canonical && <link rel="canonical" href={canonical} />}

		<meta property="og:type" content="website" />
		<meta property="og:locale" content={siteConfig.locale} />
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		{canonical && <meta property="og:url" content={canonical} />}
		{ogImage && <meta property="og:image" content={ogImage} />}

		<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{siteConfig.twitterHandle && (
			<meta name="twitter:site" content={`@${siteConfig.twitterHandle.replace(/^@/, '')}`} />
		)}
		{ogImage && <meta name="twitter:image" content={ogImage} />}
	</head>
	<body class="min-h-screen antialiased bg-white text-gray-900">
		<slot />
	</body>
</html>
