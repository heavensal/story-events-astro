---
import { getFixedT, type Locale } from "../i18n/i18n";
import weddingGlassesImage from "../../assets/images/wedding_glasses.jpg";
import weddingTableImage from "../../assets/images/wedding_table.jpg";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getFixedT(locale);

const cards = [
	{
		body: t("LandingOffer.cardExpertiseBody"),
		className: "border-white/8 bg-surface-850/85",
		id: "offer-card-expertise-title",
		title: t("LandingOffer.cardExpertiseTitle"),
	},
	{
		body: t("LandingOffer.cardMaitreHotelBody"),
		className:
			"border-silver-400/25 bg-surface-850/90 shadow-[0_0_60px_-20px_rgba(200,204,212,0.15)]",
		id: "offer-card-maitre-hotel-title",
		title: t("LandingOffer.cardMaitreHotelTitle"),
	},
];
---

<section
	id="offre"
	class="relative border-y border-white/6 bg-surface-900 px-4 py-20 md:py-28"
	aria-labelledby="heading-offer"
>
	<div class="container mx-auto max-w-5xl">
		<header class="mx-auto mb-16 max-w-2xl text-center md:mb-20">
			<h2
				id="heading-offer"
				class="mb-4 font-display text-3xl font-semibold text-silver-100 md:text-4xl"
			>
				{t("LandingOffer.title")}
			</h2>
			<p class="leading-relaxed text-silver-400">{t("LandingOffer.intro")}</p>
		</header>
		<div class="grid gap-6 lg:grid-cols-12 lg:grid-rows-[minmax(18rem,1fr)_minmax(16rem,auto)]">
			<figure
				class="group relative min-h-80 overflow-hidden rounded-sm border border-white/8 bg-surface-950 lg:col-span-7 lg:row-span-2"
			>
				<img
					src={weddingTableImage.src}
					alt={t("LandingOffer.imageTableAlt")}
					class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
				/>
				<div class="absolute inset-0 bg-linear-to-t from-surface-950/85 via-surface-950/25 to-transparent"></div>
				<figcaption class="absolute bottom-0 left-0 right-0 p-6 text-left">
					<p class="text-xs uppercase tracking-[0.35em] text-silver-400">
						Story Events
					</p>
				</figcaption>
			</figure>

			<article
				class={`rounded-sm border p-8 backdrop-blur-sm lg:col-span-5 ${cards[0].className}`}
				aria-labelledby={cards[0].id}
			>
				<p id={cards[0].id} class="mb-3 font-display text-2xl text-silver-200">
					{cards[0].title}
				</p>
				<p class="text-sm leading-relaxed text-silver-400">{cards[0].body}</p>
			</article>

			<figure
				class="relative min-h-64 overflow-hidden rounded-sm border border-silver-400/20 bg-surface-950 lg:col-span-4 lg:translate-x-6"
			>
				<img
					src={weddingGlassesImage.src}
					alt={t("LandingOffer.imageGlassesAlt")}
					class="absolute inset-0 h-full w-full object-cover"
				/>
				<div class="absolute inset-0 bg-linear-to-t from-surface-950/75 via-transparent to-transparent"></div>
			</figure>

			<article
				class={`rounded-sm border p-8 backdrop-blur-sm lg:col-span-8 lg:-translate-y-8 ${cards[1].className}`}
				aria-labelledby={cards[1].id}
			>
				<p id={cards[1].id} class="mb-3 font-display text-2xl text-silver-100">
					{cards[1].title}
				</p>
				<p class="text-sm leading-relaxed text-silver-400">{cards[1].body}</p>
			</article>
		</div>
	</div>
</section>
