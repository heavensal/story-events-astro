---
import { getFixedT, type Locale } from '../i18n/i18n';
import { pageHref, pageRoutes } from '../lib/paths';
import { siteConfig } from '../site.config';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getFixedT(locale);
const { email, phone } = siteConfig.contact;
const telDigits = phone.replace(/\D/g, '');
---

<footer class="bg-surface-950 text-silver-500 py-12 px-4 border-t border-white/6" role="contentinfo">
	<div class="container mx-auto max-w-4xl">
		<div class="text-center text-sm mb-8">
			<p class="font-display text-lg text-silver-200 mb-2">{siteConfig.name}</p>
			<p class="text-silver-400 mb-3 max-w-md mx-auto">{t('SiteFooter.tagline')}</p>
			<p class="mb-1">
				<a href={`mailto:${email}`} class="link-silver">{email}</a>
			</p>
			<p class="mb-1">
				{telDigits.length >= 8 ? (
					<a href={`tel:${telDigits}`} class="link-silver">{phone}</a>
				) : (
					<span class="text-silver-600">{phone}</span>
				)}
			</p>
		</div>
		<nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm mb-6" aria-label={t('SiteFooter.navAriaLabel')}>
			<a href={pageHref(pageRoutes.legalNotice)} class="link-silver">
				{t('SiteFooter.linkLegalNotice')}
			</a>
			<a href={pageHref(pageRoutes.privacyPolicy)} class="link-silver">
				{t('SiteFooter.linkPrivacyPolicy')}
			</a>
			<a href={pageHref(pageRoutes.termsOfService)} class="link-silver">
				{t('SiteFooter.linkTermsOfService')}
			</a>
		</nav>
		<p class="text-center text-silver-600 text-xs">{siteConfig.legalId}</p>
	</div>
</footer>
