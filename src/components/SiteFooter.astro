---
import { pageHref } from '../lib/paths';
import { siteConfig } from '../site.config';

const { email, phone } = siteConfig.contact;
const telDigits = phone.replace(/\D/g, '');
---

<footer class="bg-surface-950 text-silver-500 py-12 px-4 border-t border-white/[0.06]" role="contentinfo">
	<div class="container mx-auto max-w-4xl">
		<div class="text-center text-sm mb-8">
			<p class="font-display text-lg text-silver-200 mb-2">{siteConfig.name}</p>
			<p class="text-silver-400 mb-3 max-w-md mx-auto">{siteConfig.tagline}</p>
			<p class="mb-1">
				<a href={`mailto:${email}`} class="link-silver">{email}</a>
			</p>
			<p class="mb-1">
				{telDigits.length >= 8 ? (
					<a href={`tel:${telDigits}`} class="link-silver">{phone}</a>
				) : (
					<span class="text-silver-600">{phone}</span>
				)}
			</p>
		</div>
		<nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm mb-6" aria-label="Mentions légales et politiques">
			<a href={pageHref('mentions-legales')} class="text-silver-500 hover:text-silver-200 transition-colors">
				Mentions légales
			</a>
			<a href={pageHref('politique-confidentialite')} class="text-silver-500 hover:text-silver-200 transition-colors">
				Politique de confidentialité
			</a>
			<a href={pageHref('conditions-generales')} class="text-silver-500 hover:text-silver-200 transition-colors">
				Conditions générales
			</a>
		</nav>
		<p class="text-center text-silver-600 text-xs">{siteConfig.legalId}</p>
	</div>
</footer>
