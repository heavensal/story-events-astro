---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { siteConfig } from "../site.config";
import type { Locale } from "../i18n/i18n";
import splashArt from "../../assets/images/story_events_splash_art.jpg";

interface Props {
	locale: Locale;
	eyebrow: string;
	tagline: string;
	taglineExtension: string;
	primaryHref: string;
	primaryLabel: string;
	secondaryHref?: string;
	secondaryLabel?: string;
}

const {
	locale,
	eyebrow,
	tagline,
	taglineExtension,
	primaryHref,
	primaryLabel,
	secondaryHref,
	secondaryLabel,
} = Astro.props;
---

<section
	class="relative min-h-[88vh] w-full flex flex-col justify-center overflow-hidden px-4 py-28 bg-surface-950 text-silver-100"
	aria-labelledby="hero-brand-heading"
>
	<LanguageSwitcher {locale} />
	<div
		class="pointer-events-none absolute inset-0 opacity-50"
		aria-hidden="true"
	>
		<img
			src={splashArt.src}
			alt=""
			class="h-full w-full object-cover"
		/>
	</div>
	<div
		class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(200,204,212,0.12),transparent)]"
		aria-hidden="true"
	>
	</div>
	<div
		class="pointer-events-none absolute inset-0 opacity-[0.06] mix-blend-overlay"
		aria-hidden="true"
	>
	</div>
	<div
		class="pointer-events-none absolute bottom-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-silver-400/40 to-transparent"
		aria-hidden="true"
	>
	</div>

	<div class="relative z-10 container mx-auto max-w-3xl text-center">
		<p
			class="font-display text-silver-400 tracking-[0.35em] text-xs uppercase mb-6"
		>
			{eyebrow}
		</p>
		<h1
			id="hero-brand-heading"
			class="font-display text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.1] mb-6 text-silver-100"
		>
			{siteConfig.name}
		</h1>
		<p
			class="text-lg md:text-xl text-silver-300/95 mb-12 max-w-2xl mx-auto font-light leading-relaxed"
		>
			{tagline}
			{
				taglineExtension && (
					<>
						<span class="text-silver-100"> —</span>{taglineExtension}
					</>
				)
			}
		</p>
		<div class="flex flex-col sm:flex-row gap-4 justify-center">
			<a
				href={primaryHref}
				class="inline-flex items-center justify-center px-9 py-4 bg-linear-to-b from-silver-300 to-silver-400 text-surface-950 font-semibold tracking-wide rounded-sm hover:from-silver-200 hover:to-silver-300 transition-all shadow-[0_0_40px_-12px_rgba(200,204,212,0.45)] focus-ring"
			>
				{primaryLabel}
			</a>
			{
				secondaryHref && secondaryLabel && (
					<a
						href={secondaryHref}
						class="inline-flex items-center justify-center px-9 py-4 border border-silver-500/60 text-silver-200 font-medium rounded-sm hover:border-silver-300 hover:bg-white/4 transition-colors focus-ring"
					>
						{secondaryLabel}
					</a>
				)
			}
		</div>
	</div>
</section>
