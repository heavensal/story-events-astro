---
import { siteConfig } from '../site.config';

interface Props {
	primaryHref?: string;
	primaryLabel?: string;
	secondaryHref?: string;
	secondaryLabel?: string;
}

const {
	primaryHref = '#contact',
	primaryLabel = 'Nous contacter',
	secondaryHref,
	secondaryLabel = 'En savoir plus',
} = Astro.props;
---

<section
	class="relative min-h-[85vh] w-full flex flex-col justify-center px-4 py-24 bg-gradient-to-br from-emerald-950 via-gray-900 to-gray-950 text-white"
	aria-label="Accueil"
>
	<div class="relative z-10 container mx-auto max-w-3xl text-center">
		<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight mb-4">
			{siteConfig.name}
		</h1>
		<p class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl mx-auto">
			{siteConfig.tagline}
		</p>
		<div class="flex flex-col sm:flex-row gap-4 justify-center">
			<a
				href={primaryHref}
				class="inline-flex items-center justify-center px-8 py-4 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-500 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-900"
			>
				{primaryLabel}
			</a>
			{secondaryHref && (
				<a
					href={secondaryHref}
					class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/80 text-white font-semibold rounded-lg hover:bg-white hover:text-gray-900 transition-colors"
				>
					{secondaryLabel}
				</a>
			)}
		</div>
	</div>
</section>
