---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { siteConfig } from '../site.config';
import type { Locale } from '../i18n/i18n';

interface Props {
	locale: Locale;
	eyebrow: string;
	tagline: string;
	taglineExtension: string;
	ariaLabelHome: string;
	primaryHref: string;
	primaryLabel: string;
	secondaryHref?: string;
	secondaryLabel?: string;
}

const {
	locale,
	eyebrow,
	tagline,
	taglineExtension,
	ariaLabelHome,
	primaryHref,
	primaryLabel,
	secondaryHref,
	secondaryLabel,
} = Astro.props;
---

<section
	class="relative min-h-[88vh] w-full flex flex-col justify-center overflow-hidden px-4 py-28 bg-surface-950 text-silver-100"
	aria-label={ariaLabelHome}
>
	<LanguageSwitcher {locale} />
	<div
		class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(200,204,212,0.12),transparent)]"
		aria-hidden="true"
	/>
	<div
		class="pointer-events-none absolute inset-0 opacity-[0.06] mix-blend-overlay bg-[url('data:image/svg+xml,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20viewBox=%220%200%20256%20256%22%3E%3Cfilter%20id=%22n%22%3E%3CfeTurbulence%20type=%22fractalNoise%22%20baseFrequency=%220.9%22%20numOctaves=%224%22%20stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect%20width=%22100%25%22%20height=%22100%25%22%20filter=%22url(%23n)%22/%3E%3C/svg%3E')]"
		aria-hidden="true"
	/>
	<div class="pointer-events-none absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-silver-400/40 to-transparent" aria-hidden="true" />

	<div class="relative z-10 container mx-auto max-w-3xl text-center">
		<p class="font-display text-silver-400 tracking-[0.35em] text-xs uppercase mb-6">{eyebrow}</p>
		<h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.1] mb-6 text-silver-100">
			{siteConfig.name}
		</h1>
		<p class="text-lg md:text-xl text-silver-300/95 mb-12 max-w-2xl mx-auto font-light leading-relaxed">
			{tagline}
			<span class="text-silver-100"> — </span>{taglineExtension}
		</p>
		<div class="flex flex-col sm:flex-row gap-4 justify-center">
			<a
				href={primaryHref}
				class="inline-flex items-center justify-center px-9 py-4 bg-gradient-to-b from-silver-300 to-silver-400 text-surface-950 font-semibold tracking-wide rounded-sm hover:from-silver-200 hover:to-silver-300 transition-all shadow-[0_0_40px_-12px_rgba(200,204,212,0.45)] focus:outline-none focus-visible:ring-2 focus-visible:ring-silver-300 focus-visible:ring-offset-2 focus-visible:ring-offset-surface-950"
			>
				{primaryLabel}
			</a>
			{secondaryHref && secondaryLabel && (
				<a
					href={secondaryHref}
					class="inline-flex items-center justify-center px-9 py-4 border border-silver-500/60 text-silver-200 font-medium rounded-sm hover:border-silver-300 hover:bg-white/[0.04] transition-colors"
				>
					{secondaryLabel}
				</a>
			)}
		</div>
	</div>
</section>
