---
import { getFixedT, type Locale } from '../i18n/i18n';
import { pageHref, pageRoutes } from '../lib/paths';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getFixedT(locale);
---

<nav
	class="absolute top-6 right-4 z-20 flex items-center gap-2 text-xs font-medium tracking-wide text-silver-500"
	aria-label={t('LanguageSwitcher.ariaLabel')}
>
	{
		locale === 'fr' ? (
			<span class="rounded-sm px-1.5 py-0.5 text-silver-200" aria-current="true" lang="fr">
				{t('LanguageSwitcher.labelFr')}
			</span>
		) : (
			<a
				href={pageHref(pageRoutes.home)}
				hreflang="fr"
				lang="fr"
				title={t('LanguageSwitcher.titleFr')}
				class="rounded-sm px-1.5 py-0.5 transition-colors hover:text-silver-200 focus-ring"
			>
				{t('LanguageSwitcher.labelFr')}
			</a>
		)
	}
	<span class="text-silver-600" aria-hidden="true">|</span>
	{
		locale === 'en' ? (
			<span class="rounded-sm px-1.5 py-0.5 text-silver-200" aria-current="true" lang="en">
				{t('LanguageSwitcher.labelEn')}
			</span>
		) : (
			<a
				href={pageHref(pageRoutes.englishHome)}
				hreflang="en"
				lang="en"
				title={t('LanguageSwitcher.titleEn')}
				class="rounded-sm px-1.5 py-0.5 transition-colors hover:text-silver-200 focus-ring"
			>
				{t('LanguageSwitcher.labelEn')}
			</a>
		)
	}
</nav>
