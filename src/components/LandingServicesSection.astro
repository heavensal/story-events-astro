---
import { getFixedT, type Locale } from "../i18n/i18n";
import guestHostessImage from "../../assets/images/guest_hostess.jpg";
import headcookerImage from "../../assets/images/headcooker.jpg";
import helpHeadcookerImage from "../../assets/images/help_headcooker.jpg";
import waiterImage from "../../assets/images/waiter.jpg";
import workingManImage from "../../assets/images/working_man.jpg";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getFixedT(locale);
const services = [
	{
		image: guestHostessImage.src,
		name: t("LandingServices.itemHosts"),
	},
	{
		description: t("LandingServices.itemMaitreHotelDescription"),
		name: t("LandingServices.itemMaitreHotel"),
	},
	{
		image: headcookerImage.src,
		name: t("LandingServices.itemHeadChefs"),
	},
	{
		image: helpHeadcookerImage.src,
		name: t("LandingServices.itemKitchenAssistants"),
	},
	{
		image: waiterImage.src,
		name: t("LandingServices.itemServers"),
	},
	{
		image: workingManImage.src,
		name: t("LandingServices.itemHandlers"),
	},
];
---

<section
	id="services"
	class="bg-surface-950 px-4 py-16 text-center md:py-20"
	aria-labelledby="heading-services"
>
	<h2
		id="heading-services"
		class="mb-4 font-display text-3xl font-semibold text-silver-100 md:text-4xl"
	>
		{t("LandingServices.title")}
	</h2>
	<p class="mx-auto mb-8 max-w-3xl leading-relaxed text-silver-400">
		{t("LandingServices.intro")}
	</p>
	<div class="overflow-x-auto">
		<div class="mx-auto flex max-w-6xl snap-x snap-mandatory gap-4 px-4 py-4">
			{
				services.map((service) => (
					<article
						class="relative h-120 basis-90 shrink-0 snap-center overflow-hidden rounded-lg shadow-lg"
					>
						{
							service.image ? (
								<>
									<img
										src={service.image}
										alt={service.name}
										class="h-full w-full object-cover"
									/>
									<div
										class="absolute inset-x-0 bottom-0 bg-black/50 px-4 py-4 text-center text-white"
									>
										<p class="font-semibold">{service.name}</p>
									</div>
								</>
							) : (
								<div class="flex h-full flex-col justify-between bg-linear-to-br from-surface-900 via-surface-850 to-surface-900 p-6 text-left text-silver-100">
									<div
										class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(200,204,212,0.18),transparent_48%)]"
										aria-hidden="true"
									></div>
									<div class="relative z-10">
										<p class="mb-4 text-xs uppercase tracking-[0.35em] text-silver-400">
											Story Events
										</p>
										<h3 class="font-display text-3xl font-semibold uppercase">
											{service.name}
										</h3>
									</div>
									<p class="relative z-10 max-w-[16rem] text-sm leading-relaxed text-silver-300">
										{service.description}
									</p>
								</div>
							)
						}
					</article>
				))
			}
		</div>
	</div>
</section>
