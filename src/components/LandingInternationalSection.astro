---
import { getFixedT, type Locale } from "../i18n/i18n";
import mapImage from "../../assets/images/map.png";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getFixedT(locale);
---

<section
	class="border-t border-white/6 bg-surface-900 px-4 py-20 md:py-24"
	aria-labelledby="heading-international"
>
	<div class="container mx-auto max-w-5xl text-center">
		<p class="mb-4 text-xs uppercase tracking-[0.35em] text-silver-400">
			Story Events
		</p>
		<h2
			id="heading-international"
			class="mb-8 font-display text-3xl font-semibold uppercase text-silver-100 md:text-4xl"
		>
			{t("LandingInternational.title")}
		</h2>
		<div class="relative mx-auto mt-10 max-w-6xl lg:min-h-128">
			<figure
				class="group relative overflow-hidden rounded-sm border border-white/8 bg-surface-950 lg:ml-auto lg:w-[78%]"
			>
				<img
					src={mapImage.src}
					alt={t("LandingInternational.imageAlt")}
					class="aspect-16/10 w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
				/>
				<div class="absolute inset-0 bg-linear-to-t from-surface-950/80 via-surface-950/15 to-transparent"></div>
				<figcaption class="absolute bottom-0 left-0 right-0 p-6 text-left">
					<p class="text-xs uppercase tracking-[0.35em] text-silver-400">
						Story Events
					</p>
				</figcaption>
			</figure>
			<div
				role="article"
				class="relative z-10 mt-6 rounded-sm border border-silver-400/25 bg-surface-850/92 p-8 text-left shadow-[0_0_60px_-20px_rgba(200,204,212,0.15)] backdrop-blur-sm lg:absolute lg:bottom-10 lg:left-0 lg:mt-0 lg:max-w-md"
			>
				<p class="mb-4 text-xs uppercase tracking-[0.35em] text-silver-400">
					Story Events
				</p>
				<p class="text-lg leading-relaxed text-silver-300 md:text-xl">
					{t("LandingInternational.content")}
				</p>
			</div>
		</div>
	</div>
</section>
