---
import HeroSection from "./HeroMinimal.astro";
import LandingContactSection from "./LandingContactSection.astro";
import LandingEventsSection from "./LandingEventsSection.astro";
import LandingFaqSection from "./LandingFaqSection.astro";
import LandingInternationalSection from "./LandingInternationalSection.astro";
import LandingOfferSection from "./LandingOfferSection.astro";
import LandingRolesSection from "./LandingRolesSection.astro";
import LandingServicesSection from "./LandingServicesSection.astro";
import SiteFooter from "./SiteFooter.astro";
import { getFixedT, type Locale } from "../i18n/i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getFixedT(locale);
---

<main id="main-content" class="tracking-widest">
	<HeroSection
		{locale}
		eyebrow={t("HeroSection.eyebrow")}
		tagline={t("HeroSection.tagline")}
		taglineExtension={t("HeroSection.taglineExtension")}
		primaryHref="#contact"
		primaryLabel={t("HeroSection.primaryCta")}
		secondaryHref="#offre"
		secondaryLabel={t("HeroSection.secondaryCta")}
	/>
	<LandingOfferSection {locale} />
	<LandingServicesSection {locale} />

	<div class="py-20 md:py-24 px-4 bg-surface-950">
		<div
			class="container mx-auto max-w-5xl grid md:grid-cols-2 gap-14 md:gap-20 items-start"
		>
			<LandingRolesSection {locale} />
			<LandingEventsSection {locale} />
		</div>
	</div>
	<LandingInternationalSection {locale} />
	<LandingFaqSection {locale} />
	<LandingContactSection {locale} />
</main>
<SiteFooter {locale} />
